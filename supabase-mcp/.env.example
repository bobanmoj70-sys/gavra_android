# Supabase Configuration for MCP Server
# Get these from: https://supabase.com/dashboard/project/_/settings/api

# Project URL (required)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service Role Key - has full access (required)
# ⚠️ NEVER commit this key to version control! Use .env only.
# Get from: Settings > API > Service role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional but recommended for full SQL support with parameterized queries
# This enables execute_sql_safe, add_column, get_table_stats, and get_row_count
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Get from: Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres.xyzabc:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
