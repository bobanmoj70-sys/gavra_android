# GitHub MCP Server - Environment Configuration

# GitHub Token (Personal Access Token sa 'repo' scope)
# Kreiraj na: https://github.com/settings/tokens
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE

# GitHub Repository Owner (default: lakisa-code)
GITHUB_REPO_OWNER=lakisa-code

# GitHub Repository Name (default: gavra_android)
GITHUB_REPO_NAME=gavra_android

# Secrets payloads for setup-secrets.cjs
# Unesi direktno Base64 vrednosti ili koristi *_FILE varijante
GOOGLE_PLAY_KEY_B64=
GOOGLE_PLAY_KEY_B64_FILE=

ANDROID_KEYSTORE_B64=
ANDROID_KEYSTORE_B64_FILE=

ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEYSTORE_PASSWORD_FILE=

ANDROID_KEY_PASSWORD=
ANDROID_KEY_PASSWORD_FILE=

ANDROID_KEY_ALIAS=
