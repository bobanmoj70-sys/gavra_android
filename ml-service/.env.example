# Supabase konfiguracija
# SERVICE_ROLE_KEY je obavezan da bi AI mogao da cita sve tabele (zaobilazi RLS).
# NIKADA ga ne commit-uj u git - fajl .env je ignorisan.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# API ključ za zaštitu ML endpointa (mora se poklapati sa ML_API_KEY u Flutter app)
ML_API_KEY=your-secure-random-key-here

# Naziv Ollama modela
OLLAMA_MODEL=llama3.2

# Port na kojem će se pokrenuti FastAPI server
PORT=8000
