# Supabase konfiguracija
# SERVICE_ROLE_KEY je obavezan da bi AI mogao da cita sve tabele (zaobilazi RLS).
# NIKADA ga ne commit-uj u git - fajl .env je ignorisan.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# API ključ za zaštitu ML endpointa (mora se poklapati sa ML_API_KEY u Flutter app)
ML_API_KEY=your-secure-random-key-here

# Naziv Ollama modela
OLLAMA_MODEL=llama3.2

# Ollama parametri za kontrolu kreativnosti i dužine odgovora
OLLAMA_TEMPERATURE=0.3
OLLAMA_MAX_TOKENS=800
OLLAMA_TIMEOUT_SECONDS=30

# Keširanje čestih chat upita (smanjuje pozive ka Ollama)
CHAT_CACHE_ENABLED=true
CHAT_CACHE_MAXSIZE=100

# Port na kojem će se pokrenuti FastAPI server
PORT=8000
