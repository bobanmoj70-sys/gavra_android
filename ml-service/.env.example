# Supabase konfiguracija
# SERVICE_ROLE_KEY je obavezan da bi AI mogao da cita sve tabele (zaobilazi RLS).
# NIKADA ga ne commit-uj u git - fajl .env je ignorisan.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# API kljuÄ za zaÅ¡titu ML endpointa (mora se poklapati sa ML_API_KEY u Flutter app)
ML_API_KEY=your-secure-random-key-here

# Naziv Gemini modela
GEMINI_MODEL=gemini-3.5-flash

# Gemini API kljuc (besplatan na https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Gemini parametri za kontrolu kreativnosti i duzine odgovora
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_OUTPUT_TOKENS=800
GEMINI_TIMEOUT_SECONDS=30

# KeÅ¡iranje cestih chat upita (smanjuje pozive ka AI modelu)
CHAT_CACHE_ENABLED=true
CHAT_CACHE_MAXSIZE=100

# Port na kojem ce se pokrenuti FastAPI server
PORT=8000

# OSRM konfiguracija
# Lokalni OSRM server (Docker kontejner) - reverse proxy ide preko /osrm putanje na ovom serveru
OSRM_LOCAL_URL=http://127.0.0.1:5000
# OSRM_BASE_URL se koristi u Supabase Edge Functions (v3-compute-eta, v3-auto-prepare-termins).
# Ako koristis Tailscale Funnel: https://tvoj-tailscale-url/osrm
# Ako si u lokalnoj mrezi: http://IP_ADRESA_LAPTOPA:8000/osrm
OSRM_BASE_URL=https://tvoj-tailscale-url/osrm
