# Supabase konfiguracija
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# ML servis konfiguracija
# Zavisi gde se pokrece Flutter app:
# - Android emulator na istom racunaru: http://10.0.2.2:8000
# - Fizicki uredjaj na istoj WiFi mrezi: http://192.168.x.x:8000 (lokalna IP adresa laptopa)
# - Udaljeni pristup (telefon izvan kucne mreze): Tailscale IP ili javna adresa
ML_BASE_URL=http://192.168.x.x:8000

# API ključ za komunikaciju sa ML servisom (mora se poklapati sa ML_API_KEY na serveru)
ML_API_KEY=your-secure-random-key-here
