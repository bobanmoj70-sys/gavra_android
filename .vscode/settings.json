  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/android/**": true,
    "**/ios/**": true,
    "**/build/**": true,
    "**/.dart_tool/**": true,
    "**/coverage/**": true,
    "**/test/**": true
  },
  "search.exclude": {
    "**/android/**": true,
    "**/ios/**": true,
    "**/build/**": true,
    "**/.dart_tool/**": true,
    "**/coverage/**": true,
    "**/test/**": true
  },
  "dart.analysisExcludedFolders": [
    "android",
    "ios",
    "build",
    ".dart_tool",
    "coverage",
    "test"
  ],
  "dart.vmAdditionalArgs": [
    "--old_gen_heap_size=1024"
  ],
  // Deno configuration for Supabase Edge Functions
  "deno.enable": true,
  "deno.enablePaths": [
    "./supabase/functions"
  ],
  "deno.config": "./supabase/functions/deno.json",
  "[typescript]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  },
  "typescript.preferences.includePackageJsonAutoImports": "off",
  "typescript.suggest.autoImports": false,
  "github.copilot.chat.mcp": {
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp"
    }
  }
